# העתק לקובץ .env.local ומלא ערכים אמיתיים. אל תעשה commit ל-.env.local!
# (.env* כבר ב-.gitignore)

# --- Supabase ---
# מ-Project Settings → API ב-Supabase
NEXT_PUBLIC_SUPABASE_URL=
# publishable key (sb_publishable_...) — בטוח לחשיפה בדפדפן, RLS מגן
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# secret key (sb_secret_...) — שרת בלבד, עוקף RLS, לעולם לא נחשף ל-client
SUPABASE_SECRET_KEY=

# --- אזורים (subdomains) ---
NEXT_PUBLIC_CONTROL_PLANE_HOST=admin.localhost:3000
NEXT_PUBLIC_TENANT_HOST=app.localhost:3000
